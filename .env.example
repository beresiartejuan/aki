# Database
DB_PATH=./data/aki.db

# Ollama Cloud API
OLLAMA_API_KEY=your_key_here
OLLAMA_MODEL=qwen3.5

# Makima agent model (defaults to OLLAMA_MODEL if not set)
MAKIMA_MODEL=

# Workspace configuration
# WORKSPACE_ROOT sets the base directory for relative paths.
# If not set, defaults to the current working directory (process.cwd()).
# To restrict Makima to a specific directory, set ENABLE_SANDBOX=true.
WORKSPACE_ROOT=

# Sandbox mode
# Set to 'true' to restrict filesystem operations to WORKSPACE_ROOT.
# Default: false (Makima can access any path on the system).
ENABLE_SANDBOX=false